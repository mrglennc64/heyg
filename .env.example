# ── security ─────────────────────────────────────────────
FORGE_API_KEY=change-me-long-random
POSTGRES_PASSWORD=change-me
MINIO_ROOT_USER=forge
MINIO_ROOT_PASSWORD=change-me-too

# ── infra ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
S3_ENDPOINT=http://minio:9000
S3_BUCKET=forge-artifacts
S3_ACCESS_KEY=${MINIO_ROOT_USER}
S3_SECRET_KEY=${MINIO_ROOT_PASSWORD}

# ── generation defaults ───────────────────────────────────
DEFAULT_RESOLUTION=1920x1080
DEFAULT_FPS=25
MAX_SCRIPT_CHARS=20000
VOICE_CONCURRENCY=2
COMPOSITOR_CONCURRENCY=2
FFMPEG_HWACCEL=nvenc          # nvenc | cpu

# ── provenance (do not disable in production) ─────────────
WATERMARK_ENABLED=true
WATERMARK_KEY=change-me-watermark-secret
